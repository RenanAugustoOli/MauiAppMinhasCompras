<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppMinhasCompras.Views.ListaProduto"
             Title="Minhas Compras">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Somar" Clicked="ToolbarItem_Clicked_1" />
        <ToolbarItem Text="Adicionar" Clicked="ToolbarItem_Clicked" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto, Auto, *">
        <SearchBar Grid.Row="0" 
                   x:Name="txt_search" 
                   Placeholder="Busca de Produtos"
                   TextChanged="txt_search_TextChanged"/>

        <Grid Grid.Row="1" ColumnDefinitions="0.5*, 2*, 1*, 1*, 1*" Padding="10, 5">
            <Label Grid.Column="0" Text="ID" FontAttributes="Bold" />
            <Label Grid.Column="1" Text="Descrição" FontAttributes="Bold" />
            <Label Grid.Column="2" Text="Preço" FontAttributes="Bold" />
            <Label Grid.Column="3" Text="Qnt" FontAttributes="Bold" />
            <Label Grid.Column="4" Text="Total" FontAttributes="Bold" />
        </Grid>

        <CollectionView Grid.Row="2" x:Name="lst_produtos">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem Text="Remover"
                                           BackgroundColor="Red"
                                           Clicked="MenuItem_Clicked" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Grid ColumnDefinitions="0.5*, 2*, 1*, 1*, 1*" Padding="10, 10">
                            <Label Grid.Column="0" Text="{Binding Id}" />
                            <Label Grid.Column="1" Text="{Binding Descricao}" />
                            <Label Grid.Column="2" Text="{Binding Preco, StringFormat='{0:C}'}" />
                            <Label Grid.Column="3" Text="{Binding Quantidade}" />
                            <Label Grid.Column="4" Text="{Binding Total, StringFormat='{0:C}'}" />
                        </Grid>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <Label Text="Nenhum produto encontrado." 
                       HorizontalOptions="Center" 
                       VerticalOptions="Center" 
                       Margin="0,20,0,0" />
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>